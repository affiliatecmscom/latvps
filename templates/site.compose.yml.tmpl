# Stack 1 WP site cô lập — sinh bởi new-site.sh. Domain: __DOMAIN__
# Cô lập: DB nằm network 'internal' riêng (không thể bị site khác chạm); chỉ WP join 'proxy' để Caddy vào.
# KHÔNG publish port ra host — Caddy reverse_proxy qua network wpfactory_proxy.
name: site-__SLUG__

services:
  db:
    image: mariadb:11
    container_name: __SLUG___db
    restart: unless-stopped
    environment:
      MARIADB_DATABASE: wordpress
      MARIADB_USER: wordpress
      MARIADB_PASSWORD: ${DB_PASSWORD}
      MARIADB_RANDOM_ROOT_PASSWORD: "1"
    volumes:
      - db:/var/lib/mysql
    networks:
      - internal
    security_opt:
      - no-new-privileges:true
    mem_limit: 512m

  wp:
    image: wordpress:6-php8.3-apache
    container_name: __SLUG___wp
    restart: unless-stopped
    environment:
      WORDPRESS_DB_HOST: db
      WORDPRESS_DB_USER: wordpress
      WORDPRESS_DB_PASSWORD: ${DB_PASSWORD}
      WORDPRESS_DB_NAME: wordpress
    volumes:
      - ./wp-content:/var/www/html/wp-content
    networks:
      - internal
      - proxy
    security_opt:
      - no-new-privileges:true
    mem_limit: 512m
    depends_on:
      - db

networks:
  internal:
  proxy:
    external: true
    name: wpfactory_proxy

volumes:
  db:
