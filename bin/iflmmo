#!/usr/bin/env bash
# iflmmo — CLI quản lý WP Factory. Không tham số -> menu TUI; có subcommand -> chạy thẳng.
set -euo pipefail

# Tìm thư mục thật (theo symlink /usr/local/bin/iflmmo -> /opt/wp-factory/bin/iflmmo).
SELF="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
BIN_DIR="$(cd "$(dirname "$SELF")" && pwd)"
ROOT_DIR="$(cd "${BIN_DIR}/.." && pwd)"

# common.sh tự set WPF_ROOT đúng (theo vị trí của chính nó).
source "${ROOT_DIR}/lib/common.sh"
source "${ROOT_DIR}/lib/ui.sh"
for a in "${WPF_ROOT}"/lib/actions/*.sh; do source "$a"; done
source "${WPF_ROOT}/lib/menu.sh"

print_help() {
  cat <<EOF
iflmmo — quản lý WP Factory (nhiều WordPress site cô lập trên 1 VPS)

  iflmmo                          mở menu quản lý (TUI)
  iflmmo add [domain] [--type affiliatecms|vanilla] [--canonical www|non-www|none] [--email e]
  iflmmo ls                       liệt kê site
  iflmmo rm <id|domain> [--yes]   xoá site
  iflmmo domain <id|domain> <new-domain>
  iflmmo canonical <id|domain> <www|non-www|none>
  iflmmo backup [id|domain|all]
  iflmmo restore <id|domain> <file.tar.gz>
  iflmmo license                  xem/đổi license
  iflmmo status                   trạng thái hệ thống
  iflmmo logs <id|domain> [wp|db]
  iflmmo update                   cập nhật hệ thống (image + OS)
  iflmmo self-update              cập nhật chính lệnh iflmmo
  iflmmo payload-sync [src]       cập nhật plugin bundle
  iflmmo setup                    (lại) bootstrap host
  iflmmo version                  phiên bản
EOF
}

cmd="${1:-menu}"; shift || true
case "$cmd" in
  menu)         require_root; main_menu ;;
  add)          require_root; act_site_add "$@" ;;
  ls|list)      act_site_list_print ;;
  rm|remove)    require_root; act_site_remove "$@" ;;
  domain)       require_root; act_site_domain "$@" ;;
  canonical)    require_root; act_site_canonical "$@" ;;
  backup)       require_root; act_backup "$@" ;;
  restore)      require_root; act_restore "$@" ;;
  license)      require_root; act_license ;;
  status)       act_status ;;
  logs)         require_root; act_logs "$@" ;;
  update)       require_root; act_update ;;
  self-update)  require_root; act_self_update ;;
  payload-sync) require_root; act_payload_sync "$@" ;;
  setup)        act_setup ;;
  version|-v|--version) cat "${WPF_ROOT}/VERSION" 2>/dev/null || echo "unknown" ;;
  -h|--help|help) print_help ;;
  *) die "Lệnh không rõ: $cmd  (xem: iflmmo --help)" ;;
esac
